{
  "name": "ai-commit-message-gen",
  "displayName": "AI Commit Message Generator",
  "description": "Generate conventional commit messages using AI models. Replaces the built-in commit message generator with a configurable, reliable alternative.",
  "version": "0.1.0",
  "publisher": "Nolomon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nolomon/Commit-Message-Gen-VS-X.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "commit",
    "ai",
    "claude",
    "openai",
    "gemini",
    "deepseek",
    "mistral",
    "conventional-commits"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionDependencies": [
    "vscode.git"
  ],
  "icon": "resources/icon.png",
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "commitMessageGen.generate",
        "title": "AI: Generate Commit Message",
        "icon": {
          "light": "resources/light/sparkle.svg",
          "dark": "resources/dark/sparkle.svg"
        }
      },
      {
        "command": "commitMessageGen.setApiKey",
        "title": "AI Commit: Set API Key"
      },
      {
        "command": "commitMessageGen.clearApiKey",
        "title": "AI Commit: Clear API Key"
      },
      {
        "command": "commitMessageGen.setModel",
        "title": "AI Commit: Set Model"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "commitMessageGen.generate",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ]
    },
    "configuration": {
      "title": "AI Commit Message Generator",
      "properties": {
        "commitMessageGen.model": {
          "type": "string",
          "enum": [
            "claude-sonnet-4-6",
            "claude-opus-4-6",
            "claude-haiku-4-5",
            "gpt-4o",
            "gpt-4o-mini",
            "o3-mini",
            "gemini-2.5-pro",
            "gemini-2.0-flash",
            "deepseek-chat",
            "deepseek-reasoner",
            "mistral-large-latest",
            "codestral-latest"
          ],
          "enumItemLabels": [
            "Claude — Sonnet 4.6",
            "Claude — Opus 4.6",
            "Claude — Haiku 4.5",
            "GPT — 4o",
            "GPT — 4o Mini",
            "GPT — o3-mini",
            "Gemini — 2.5 Pro",
            "Gemini — 2.0 Flash",
            "DeepSeek — V3",
            "DeepSeek — R1",
            "Mistral — Large",
            "Mistral — Codestral"
          ],
          "markdownEnumDescriptions": [
            "_Anthropic_ · Claude Sonnet 4.6 — fast, balanced all-rounder",
            "_Anthropic_ · Claude Opus 4.6 — most capable Claude model",
            "_Anthropic_ · Claude Haiku 4.5 — lightweight and fast",
            "_OpenAI_ · GPT-4o — high-intelligence flagship",
            "_OpenAI_ · GPT-4o Mini — affordable small model",
            "_OpenAI_ · o3-mini — fast reasoning model",
            "_Google_ · Gemini 2.5 Pro — thinking model for complex tasks",
            "_Google_ · Gemini 2.0 Flash — fast and versatile",
            "_DeepSeek_ · V3 — fast general-purpose chat model",
            "_DeepSeek_ · R1 — reasoning model",
            "_Mistral_ · Large — flagship multilingual model",
            "_Mistral_ · Codestral — specialized for code"
          ],
          "default": "claude-sonnet-4-6",
          "description": "AI model to use for commit message generation. The provider is determined automatically from the selected model."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "compile": "tsc -p ./",
    "package": "npm run build && npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0"
  }
}
